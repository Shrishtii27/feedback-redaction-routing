# Open Source LLM / OpenAI Compatible Configuration
# If neither is configured, the application falls back automatically to local rules/regex.

# AI_API_KEY: API Key (e.g. from OpenAI, DeepSeek, Together, etc.). Optional if using local Ollama.
AI_API_KEY="MY_AI_API_KEY"

# AI_BASE_URL: Base URL of the OpenAI-compatible endpoint.
# Use http://localhost:11434/v1 for Ollama, http://localhost:1234/v1 for LM Studio, etc.
AI_BASE_URL="http://localhost:11434/v1"

# AI_MODEL: The model name to query (e.g. llama3, mistral, deepseek-chat, gpt-4o-mini).
AI_MODEL="llama3"

# APP_URL: The URL where this service is hosted.
APP_URL="http://localhost:3000"
